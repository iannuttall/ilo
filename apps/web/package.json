{
  "name": "@ilo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build --config astro.config.mjs && node scripts/finalize-astro-build.mjs && node scripts/build-agent-assets.mjs && node scripts/check-astro-build.mjs",
    "clean": "rm -rf .astro dist .wrangler",
    "dev": "pnpm run build && pnpm exec wrangler dev --config dist/server/wrangler.json --port ${PORT:-3000}",
    "preview": "pnpm run dev",
    "deploy": "pnpm run build && pnpm exec wrangler deploy",
    "deploy:dry-run": "pnpm run build && pnpm exec wrangler deploy --dry-run",
    "lint": "astro check --config astro.config.mjs",
    "test": "vitest run --passWithNoTests",
    "typecheck": "astro check --config astro.config.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@kiwa-ui/enhance": "^2.1.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-slot": "1.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.30",
    "linkedom": "^0.18.13",
    "lucide": "^1.24.0",
    "lucide-react": "^1.24.0",
    "marked": "^17.0.6",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^22.20.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}

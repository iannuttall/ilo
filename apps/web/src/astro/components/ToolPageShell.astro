---
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from '@/astro/components/ui/accordion'
import type { AstroTool } from '../data/tools'
import type {
  ToolContentSection,
  ToolFaq,
} from '../data/tool-page-content'

type Props = {
  toolTitle: string
  heading: string
  description: string
  sections?: ToolContentSection[]
  faqs?: ToolFaq[]
  otherTools: AstroTool[]
}

const {
  toolTitle,
  heading,
  description,
  sections = [],
  faqs = [],
  otherTools,
} = Astro.props
const faqJsonLd =
  faqs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
          '@type': 'Question',
          name: faq.question,
          acceptedAnswer: { '@type': 'Answer', text: faq.answer },
        })),
      }
    : null
---

<main>
  <section class="border-b border-border bg-background pt-4 text-foreground">
    <div class="site-frame">
      <nav aria-label="Breadcrumb" class="pt-6 text-sm text-foreground-muted">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li>
            <a
              class="underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
              href="/"
            >
              Home
            </a>
          </li>
          <li aria-hidden="true" class="text-border">/</li>
          <li>
            <a
              class="underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
              href="/tools"
            >
              Tools
            </a>
          </li>
          <li aria-hidden="true" class="text-border">/</li>
          <li class="text-foreground">{toolTitle}</li>
        </ol>
      </nav>
      <div class="flex flex-col gap-8 pt-16 sm:pt-24">
        <div class="flex max-w-3xl flex-col gap-4">
          <h1 class="max-w-3xl text-pretty text-3xl/none font-medium tracking-normal sm:text-4xl/none">
            {heading}
          </h1>
          <p class="text-pretty text-2xl/8 font-medium tracking-normal text-foreground-muted">
            {description}
          </p>
        </div>
        <div>
          <slot />
        </div>
      </div>
    </div>
  </section>

  <section id="tool-result-root" class="site-frame tool-result-root"></section>

  {sections.length || faqs.length ? (
    <section class="site-frame py-16 sm:py-20">
      <div class="space-y-12">
        {sections.length ? (
          <article class="docs-prose">
          {sections.map((section) => (
            <>
              <h2>{section.heading}</h2>
              <Fragment set:html={section.html} />
            </>
          ))}
          </article>
        ) : null}

        {faqs.length ? (
          <section>
            <h2 class="text-2xl/8 font-medium tracking-normal">
              Frequently asked questions
            </h2>
            <Accordion class="mt-6 overflow-hidden rounded-lg bg-muted">
              {faqs.map((faq) => (
                <AccordionItem
                  value={faq.question}
                  class="rounded-none border-t border-border first:border-t-0"
                >
                  <AccordionTrigger>{faq.question}</AccordionTrigger>
                  <AccordionContent>
                    <p>{faq.answer}</p>
                  </AccordionContent>
                </AccordionItem>
              ))}
            </Accordion>
          </section>
        ) : null}
      </div>
    </section>
  ) : null}

  <section class="site-frame py-16 sm:py-20">
    <h2 class="text-2xl/8 font-medium tracking-normal">Other tools</h2>
    <div class="mt-6 grid gap-2 sm:grid-cols-2">
      {otherTools.map((tool) => (
        <a
          class="flex min-h-40 flex-col rounded-lg bg-muted p-6 no-underline transition-colors hover:bg-secondary-hover focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/20"
          href={tool.href}
        >
          <h3 class="text-lg/6 font-medium tracking-normal">{tool.title}</h3>
          <p class="mt-3 text-base/7 text-foreground-muted">{tool.description}</p>
        </a>
      ))}
    </div>
  </section>
</main>

{faqJsonLd ? (
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
) : null}

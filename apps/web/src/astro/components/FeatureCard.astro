const Tag = href ? 'a' : 'div'
---

<Tag href={href} class:list={['flex h-full', href && 'no-underline']}>
  <div
    class="group -m-4 flex w-full flex-col gap-3 rounded-lg p-4 transition-colors hover:bg-muted/50"
  >
    <span class="text-primary">
      <svg
        class="size-5 shrink-0"
        viewBox="0 0 256 256"
        fill="currentColor"
        aria-hidden="true"
      >
        {paths.map((path) => <path d={path.d} opacity={path.opacity}></path>)}
      </svg>
    </span>
    <div class="flex-1">
      <h3 class="text-lg font-medium text-foreground">{title}</h3>
      <p class="mt-1.5 text-base/7 text-secondary-foreground">{description}</p>
    </div>
  </div>
</Tag>

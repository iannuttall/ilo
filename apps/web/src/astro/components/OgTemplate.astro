            d="M5.74328698,62.7044024 C6.00153275,60.4227868 8.06049717,58.7825215 10.3421127,59.0407673 C12.6237283,59.299013 14.2639936,61.3579775 14.0057478,63.639593 C13.0015813,72.5114594 15.0095316,81.3277052 19.1290517,86.1453268 C23.5244388,91.2855643 29.3798699,93.8230926 36.448925,93.4925259 C38.7426025,93.3852678 40.6889453,95.1577109 40.7962033,97.4513883 C40.9034614,99.7450657 39.1310184,101.691408 36.8373409,101.798667 C27.2022283,102.249229 18.8716706,98.6390715 12.8092749,91.549331 C7.02642312,84.7865065 4.49962897,73.6921891 5.74328698,62.7044024 Z"
            transform="translate(23.1171, 80.4251) rotate(-14) translate(-23.1171, -80.4251)"
          ></path>
        </g>
      </svg>
    </div>

    <div
      style="flex:1;display:flex;flex-direction:column;justify-content:center;max-width:900px"
    >
      <div
        id="og-title"
        style="font-size:64px;font-weight:550;line-height:1.12;color:#1f1f1f;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical"
      >
      </div>
      <div
        id="og-desc"
        style="font-size:44px;font-weight:450;line-height:1.4;color:#666;margin-top:24px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical"
      >
      </div>
    </div>
  </div>
</div>

<template
  data-og-template
  data-og-width={String(OG_TEMPLATE_WIDTH)}
  data-og-height={String(OG_TEMPLATE_HEIGHT)}
></template>

<script is:inline>
  ;(() => {
    const stripSiteName = (raw) =>
      String(raw || '')
        .replace(/^(?:ilo|ilo\.so)\s*[|\u2013\u2014-]\s*/i, '')
        .replace(/\s*[|\u2013\u2014-]\s*(?:ilo|ilo\.so)$/i, '')
        .trim()

    const src = document.getElementById('og-content')
    const tpl = document.querySelector('template[data-og-template]')
    if (!src || !tpl) return

    const title = stripSiteName(document.title) || document.title || ''
    const desc =
      document
        .querySelector('meta[name="description"]')
        ?.getAttribute('content') || ''

    const titleEl = src.querySelector('#og-title')
    if (titleEl) titleEl.textContent = title

    const descEl = src.querySelector('#og-desc')
    if (descEl) {
      descEl.textContent = desc
      if (!desc) descEl.style.display = 'none'
    }

    tpl.innerHTML = src.innerHTML

    const ogParam = new URLSearchParams(window.location.search).get('og')
    let overlay
    if (ogParam === '' || ogParam === 'preview' || ogParam === '1') {
      overlay = document.createElement('div')
      overlay.style.cssText =
        'position:fixed;inset:0;z-index:99999;background:#666;display:flex;align-items:center;justify-content:center'
      overlay.innerHTML = src.innerHTML
      document.body.appendChild(overlay)
    }

    Promise.resolve(document.fonts?.ready).finally(() => {
      window.__OG_READY__ = true
    })

    window.addEventListener('pagehide', () => overlay?.remove(), { once: true })
  })()
</script>

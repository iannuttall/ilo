            d="M30.2958418,-0.850677796 C30.7656582,-3.09828385 32.9685643,-4.53946714 35.2161704,-4.06965077 C37.4637765,-3.59983439 38.9049597,-1.39692826 38.4351434,0.850677796 C34.7520699,18.4705368 32.8270196,32.6662904 31.5780597,48.1566861 C31.5502381,48.5017476 31.5228465,48.838801 31.4812968,49.3481933 C30.3206064,63.5780665 30.7718408,68.8193125 33.141908,69.9946994 C35.4326803,71.1307616 38.3186699,70.5696158 41.115211,68.2393699 C42.879252,66.7694651 45.5008829,67.0079096 46.9707877,68.7719505 C48.4406925,70.5359914 48.202248,73.1576224 46.4382071,74.6275272 C41.2741896,78.9304964 34.9314062,80.1637741 29.4475061,77.4441447 C25.1514362,75.3135956 23.1938332,70.9813575 22.6647352,64.835699 C22.3201057,60.8327074 22.4819955,57.3963877 23.1936036,48.6721896 C23.2349595,48.1651732 23.2621732,47.8303077 23.2897394,47.4884153 C24.5650919,31.6706805 26.5361234,17.1358514 30.2958418,-0.850677796 Z"

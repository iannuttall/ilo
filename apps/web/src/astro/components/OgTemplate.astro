---
const OG_TEMPLATE_WIDTH = 1200
const OG_TEMPLATE_HEIGHT = 630
---

<div id="og-content" style="display:none">
  <div
    style={`width:${OG_TEMPLATE_WIDTH}px;height:${OG_TEMPLATE_HEIGHT}px;background:#fafafa;display:flex;flex-direction:column;justify-content:space-between;font-family:'InterVariable','Inter',ui-sans-serif,system-ui,sans-serif;padding:80px 80px 56px;box-sizing:border-box`}
  >
    <div style="display:flex;align-items:center">
      <svg
        viewBox="0 0 81.0987986 109.636799"
        fill="#1f1f1f"
        width="42"
        height="57"
        aria-hidden="true"
      >
        <g
          transform="translate(4.4375, 4.1584)"
          fill-rule="nonzero"
          stroke="none"
          stroke-width="1"
        >
          <ellipse
            transform="translate(4.3042, 44.3206) rotate(4) translate(-4.3042, -44.3206)"
            cx="4.30416033"
            cy="44.3206117"
            rx="4"
            ry="4.5"></ellipse>
          <path
            d="M4.30416033,35.663003 C8.92569454,35.663003 12.461769,39.6410868 12.461769,44.3206117 C12.461769,49.0001366 8.92569454,52.9782204 4.30416033,52.9782204 C-0.317373878,52.9782204 -3.85344836,49.0001366 -3.85344836,44.3206117 C-3.85344836,39.6410868 -0.317373878,35.663003 4.30416033,35.663003 Z"
            transform="translate(4.3042, 44.3206) rotate(4) translate(-4.3042, -44.3206)"
          ></path>
          <path
            d="M59.2974667,27.1969346 C68.3525145,27.1969346 75.4550754,35.3048213 75.4550754,45.0530727 C75.4550754,54.8013242 68.3525145,62.9092108 59.2974667,62.9092108 C50.2424189,62.9092108 43.139858,54.8013242 43.139858,45.0530727 C43.139858,35.3048213 50.2424189,27.1969346 59.2974667,27.1969346 Z M59.2974667,35.512152 C55.0976805,35.512152 51.4550754,39.6703464 51.4550754,45.0530727 C51.4550754,50.435799 55.0976805,54.5939935 59.2974667,54.5939935 C63.4972529,54.5939935 67.139858,50.435799 67.139858,45.0530727 C67.139858,39.6703464 63.4972529,35.512152 59.2974667,35.512152 Z"
            transform="translate(59.2975, 45.0531) rotate(4) translate(-59.2975, -45.0531)"
          ></path>

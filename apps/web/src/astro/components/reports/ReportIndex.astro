---
import { xReportDocGroups } from '@/lib/x-report-docs'
import PageHeader from '@/astro/components/PageHeader.astro'

type Props = {
  basePath: '/reports' | '/docs/reports'
}

const { basePath } = Astro.props
const isDocs = basePath === '/docs/reports'
---

<main class="site-frame py-10" data-agent-content>
  <nav aria-label="Breadcrumb" class="mb-6 text-sm text-foreground-muted">
    <ol class="flex flex-wrap items-center gap-1.5">
      <li>
        <a
          class="underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
          href="/"
        >
          Home
        </a>
      </li>
      <li aria-hidden="true" class="text-border">/</li>
      {
        isDocs ? (
          <>
            <li>
              <a
                class="underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
                href="/docs"
              >
                Docs
              </a>
            </li>
            <li aria-hidden="true" class="text-border">/</li>
          </>
        ) : null
      }
      <li class="text-foreground">Reports</li>
    </ol>
  </nav>

  <PageHeader
    title="𝕏 performance report guides"
    description="Choose the question you need answered. Each guide shows what to collect, how to inspect it, and what the result can support."
    bordered={false}
  />

  <article class="docs-prose">
    <p>
      Start with the decision in front of you. Account snapshot gives you a
      broad read, while focused guides compare topics, hooks, formats, timing,
      and audience response. Every guide includes a concrete example, a prompt
      for your agent, and separate workflows for the CLI, local MCP, and
      TypeScript package.
    </p>
    <p>
      These are research guides today. ilo does not yet import a complete X
      post history or produce these reports through one automated command. The
      pages state that limit and show how to carry out the analysis without
      pretending missing data is a result.
    </p>
  </article>

  <div class="mt-12 space-y-14">
    {
      xReportDocGroups.map((group) => (
        <section>
          <header class="max-w-2xl">
            <h2 class="text-2xl/8 font-medium text-foreground">
              {group.title}
            </h2>
            <p class="mt-2 text-base/7 text-foreground-muted">
              {group.description}
            </p>
          </header>
          <div class="mt-6 grid gap-2 sm:grid-cols-2">
            {group.docs.map((doc) => (
              <a
                href={`${basePath}/${doc.slug}`}
                class="group flex min-h-44 flex-col rounded-lg bg-muted p-6 no-underline transition-colors hover:bg-secondary-hover"
              >
                <span class="block text-base font-medium text-foreground">
                  {doc.title}
                </span>
                <span class="mt-3 block text-sm/6 text-foreground-muted">
                  {doc.description}
                </span>
                <span class="mt-auto pt-5 text-xs font-medium text-foreground-soft">
                  Full research guide
                </span>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</main>

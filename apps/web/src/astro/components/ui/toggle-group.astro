---
import { cn } from '@/lib/utils'

type ToggleGroupProps = {
  type?: 'single' | 'multiple'
  variant?: 'default' | 'outline'
  size?: 'default' | 'sm'
  class?: string
}

const {
  type = 'single',
  variant = 'default',
  size = 'default',
  class: className,
} = Astro.props as ToggleGroupProps
---

<div
  data-toggle-group
  data-toggle-type={type}
  role="group"
  class={cn(
    'inline-flex items-center justify-center gap-1 rounded-lg',
    variant === 'outline'
      ? 'bg-card ring ring-border text-foreground-muted'
      : 'bg-muted text-foreground-muted',
    size === 'sm'
      ? 'h-8 p-0.5 [&_[data-toggle-item]]:h-7 [&_[data-toggle-item]]:min-w-7 [&_[data-toggle-item]]:rounded-md [&_[data-toggle-item]]:px-2.5'
      : 'h-9 p-0.5 [&_[data-toggle-item]]:h-8 [&_[data-toggle-item]]:min-w-7 [&_[data-toggle-item]]:px-3',
    className,
  )}
  data-variant={variant}
  data-size={size}
>
  <slot />
</div>

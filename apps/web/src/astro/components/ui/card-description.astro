---
import { cn } from "@/lib/utils";
import type { HTMLAttributes } from 'astro/types'

type CardProps = HTMLAttributes<'div'>;

const {
  class: className,
  ...props
} = Astro.props as CardProps
---
<div
    data-slot="card-description"
    class={cn("text-foreground-muted text-sm", className)}
    {...props}
  >
    <slot />
  </div>

---
import HeroPanel from '../components/HeroPanel.astro'
import InstallPicker from '../components/InstallPicker.astro'
import SectionHeading from '../components/SectionHeading.astro'
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from '../components/ui/accordion'
import BaseLayout from '../layouts/BaseLayout.astro'
import { reportGroups } from '../../lib/x-report-catalog'

const buttonBase =
  'inline-flex h-10 items-center justify-center gap-2 whitespace-nowrap rounded-lg border border-transparent px-6 text-sm font-medium transition-all outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/20'
const secondaryButton = `${buttonBase} bg-secondary text-secondary-foreground hover:bg-secondary-hover`

const faqs = [
  {
    question: 'What does ilo help me do?',
    answer:
      'Use public X performance evidence to plan stronger posts, save the ideas worth keeping, schedule them, and publish after you approve the final text.',
  },
  {
    question: 'What does ilo help me analyze?',
    answer:
      'The report library covers top posts, weak posts, topics, hooks, formats, media, links, timing, replies, reposts, reach signals, and repeated patterns. Each guide explains what evidence to inspect and how to read it.',
  },
  {
    question: 'Can I research competitors or clients?',
    answer:
      'Yes. The public research tools and report guides work with public handles and post data, which makes them useful for client work, market research, and competitor reviews.',
  },
  {
    question: 'What makes this different from generic content advice?',
    answer:
      'Generic advice starts with averages. ilo gives your agent a process for working from the profile and posts you care about, recording the evidence, and keeping recommendations tied to that sample.',
  },
  {
    question: 'What does my agent get back?',
    answer:
      'A useful answer includes the posts or profile signals behind each finding, the pattern they support, the limits of the sample, and a short list of next actions. That is much more useful than being told to post more often.',
  },
  {
    question: 'Can ilo draft and publish posts?',
    answer:
      'Yes. Create a draft from the terminal or an agent, review the exact text, then publish it to X. Publishing always requires explicit confirmation.',
  },
  {
    question: 'Can ilo schedule posts?',
    answer:
      'Yes. Schedule a draft with an exact timestamp or a phrase such as `tomorrow at 9am`. Run the scheduler as a watcher or call it from your normal task runner.',
  },
  {
    question: 'How does an agent use ilo?',
    answer:
      'Add the local MCP server to Claude, Codex, Cursor, or another compatible client. The ilo skill teaches the agent how to research, draft, schedule, and ask for confirmation before publishing.',
  },
  {
    question: 'Do I need to use an agent?',
    answer:
      'No. Every drafting, scheduling, and publishing action is available from the CLI. The MCP server and skill give an agent access to the same workflow.',
  },
  {
    question: 'Which social networks does ilo support?',
    answer:
      'X publishing comes first. The public tools also cover Bluesky profiles and link previews. Bluesky and LinkedIn publishing are planned next.',
  },
  {
    question: 'How can I support the project?',
    answer:
      'Star the repository, contribute a fix or provider, or sponsor Ian on GitHub if ilo saves you time.',
  },
]
---

<BaseLayout
  title="Twitter Analytics for Agents: Open Source X Tools"
  description="Use X performance evidence to plan better posts, save drafts, schedule them, and publish with an open source workflow built for agents."
>
  <main data-agent-content="true">
    <section class="flex flex-col border-b border-border bg-background pt-4 text-foreground">
      <div class="site-frame">
        <div class="flex flex-col gap-8 pt-16 sm:pt-24">
          <div class="flex max-w-2xl flex-col gap-4">
            <h1 class="max-w-xl text-pretty text-3xl font-medium -tracking-[0.5px] xl:text-4xl xl:-tracking-[0.7px]">
              Turn your agents into social media marketers that grow your 𝕏 audience.
            </h1>
            <p class="text-pretty text-2xl/8 font-medium -tracking-[0.2px] text-foreground-muted xl:text-3xl/10 xl:-tracking-[0.4px]">
              Use performance evidence to plan better posts, turn the strongest
              ideas into drafts, and publish them with an agent that knows the
              workflow.
            </p>
          </div>
          <InstallPicker />
        </div>
      </div>
    </section>

    <div class="space-y-24 py-24">
      <section class="site-frame grid grid-cols-1 gap-2 sm:grid-cols-2">
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">Find what keeps working.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            Compare strong and weak posts, then inspect the topics, hooks,
            formats, timing, and audience response behind them.
          </p>
        </div>
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">Turn evidence into a draft.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            Give your agent the account context, keep its recommendations tied
            to real examples, and save the ideas worth publishing.
          </p>
        </div>
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">Schedule without date maths.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            Queue a post for tomorrow morning or Friday at 2pm. ilo turns the
            phrase into the right local time and keeps the draft ready.
          </p>
        </div>
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">Keep approval in the loop.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            Review the exact text and destination before anything is published.
            The CLI and agent tools use the same confirmation rule.
          </p>
        </div>
      </section>

      <section class="site-frame">
        <SectionHeading
          eyebrow="Agents in the loop"
          text="Ask an agent to prepare a draft, review it yourself, then explicitly approve publishing. ilo handles the local plumbing."
        />
        <HeroPanel />
      </section>

      <section class="site-frame">
        <SectionHeading
          eyebrow="Free X research guides"
          text="Turn public X profile and post data into evidence your agent can use when it plans what to publish next."
        />
        <div class="grid grid-cols-1 gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
          {reportGroups.map((group) => (
            <section>
              <h3 class="text-lg font-medium text-foreground">{group.title}</h3>
              <ul class="mt-3 flex flex-col gap-1.5 text-base text-foreground-muted">
                {group.reports.map((report) => (
                  <li>
                    <a
                      class="text-primary underline decoration-2 underline-offset-4 hover:text-primary-hover"
                      href={`/reports/${report.slug}`}
                    >
                      {report.title}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>

      <section class="site-frame">
        <div>
          <div class="max-w-2xl">
            <h2 class="text-pretty text-2xl font-medium -tracking-[0.4px] text-foreground xl:text-3xl xl:-tracking-[0.6px]">
              Questions about using ilo for X
            </h2>
            <p class="mt-4 text-pretty text-xl/7 font-medium -tracking-[0.15px] text-foreground-muted xl:text-2xl/8 xl:-tracking-[0.3px]">
              Start with the account and posts you care about. ilo helps your
              agent research what worked, prepare the next post, and publish it
              when you are ready.
            </p>
          </div>

          <Accordion class="mt-10 overflow-hidden rounded-lg bg-muted">
            {faqs.map((item) => (
              <AccordionItem
                class="rounded-none border-b border-border bg-transparent last:border-b-0"
                value={item.question}
              >
                <AccordionTrigger>{item.question}</AccordionTrigger>
                <AccordionContent>
                  <p class="text-base leading-7 text-foreground-muted">{item.answer}</p>
                </AccordionContent>
              </AccordionItem>
            ))}
          </Accordion>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

---
import ReportGuide from '@/astro/components/reports/ReportGuide.astro'
import BaseLayout from '@/astro/layouts/BaseLayout.astro'
import {
  getXReportDoc,
  xReportDocs,
} from '@/lib/x-report-docs'

export const prerender = true
export const getStaticPaths = () =>
  xReportDocs.map((doc) => ({ params: { slug: doc.slug } }))

const slug = Astro.params.slug ?? ''
const doc = getXReportDoc(slug)
if (!doc) return Astro.rewrite('/404')
---

<BaseLayout
  title={doc.seoTitle}
  description={doc.seoDescription}
  canonical={`/docs/reports/${doc.slug}`}
>
  <ReportGuide {doc} basePath="/docs/reports" />
</BaseLayout>

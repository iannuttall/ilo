---
import { xReportDocGroups, xReportDocPath } from '../../../../lib/x-report-docs'
import PageHeader from '../../../components/PageHeader.astro'
import BaseLayout from '../../../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Twitter Analytics Reports: 𝕏 Audit and Performance Docs"
  description="Choose the right ilo report for 𝕏 performance audits, Twitter analytics, post patterns, audience response, and agent briefs."
>
  <main class="site-frame py-10">
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-foreground-muted">
      <ol class="flex flex-wrap items-center gap-1.5">
        <li>
          <a
            class="underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
            href="/"
          >
            Home
          </a>
        </li>
        <li aria-hidden="true" class="text-border">/</li>
        <li>
          <a
            class="underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
            href="/docs"
          >
            Docs
          </a>
        </li>
        <li aria-hidden="true" class="text-border">/</li>
        <li class="text-foreground">Reports</li>
      </ol>
    </nav>

    <PageHeader
      title="𝕏 performance reports for agents"
      description="Choose the guide that matches the question. Each page explains when to use it, what to inspect, and how an agent should read the evidence."
      bordered={false}
    />

    <div class="docs-prose mt-8">
      <p>
        Start with the question you need to answer, then give your agent a
        representative set of public profile and post data. Each guide explains
        the evidence to inspect and the limits to include in the result.
      </p>
    </div>

    <div class="mt-10 space-y-14">
      {xReportDocGroups.map((group) => (
        <section>
          <header class="max-w-2xl">
            <h2 class="text-2xl/8 font-medium text-foreground">{group.title}</h2>
            <p class="mt-2 text-base/7 text-foreground-muted">{group.description}</p>
          </header>
          <div class="mt-6 grid gap-2 sm:grid-cols-2">
            {group.docs.map((doc) => (
              <a
                href={xReportDocPath(doc)}
                class="group flex min-h-40 flex-col rounded-lg bg-muted p-6 no-underline transition-colors hover:bg-secondary-hover"
              >
                <span class="block text-base font-medium text-foreground">
                  {doc.title}
                </span>
                <span class="mt-3 block text-sm/6 text-foreground-muted">
                  {doc.description}
                </span>
                <span class="mt-auto pt-5 text-xs font-medium text-foreground-soft">
                  Research guide
                </span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>

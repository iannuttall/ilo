---
import { DOCS_MANIFEST } from '../../../lib/docs-manifest'
import BaseLayout from '../../layouts/BaseLayout.astro'
import InstallPicker from '../../components/InstallPicker.astro'
import PageHeader from '../../components/PageHeader.astro'

export const prerender = true

const docsCards = [
  ...DOCS_MANIFEST.map((doc) => ({
    title: doc.title,
    description: doc.description,
    href: `/docs/${doc.slug}`,
  })),
  {
    title: 'Reports',
    description:
      'Choose the right 𝕏 report and see how agents should run, read, and follow it up.',
    href: '/docs/reports',
  },
]
---

<BaseLayout
  title="Twitter Analytics Docs: MCP, CLI and TypeScript"
  description="Use ilo's Twitter analytics guides, CLI, local MCP server, agent skill, and TypeScript package."
>
  <main class="site-frame py-10">
    <PageHeader
      title="Use ilo with your agent, terminal, or code."
      description="Install the CLI, connect Typefully or direct X, add the local MCP server, or import ilo in a TypeScript project."
      bordered={false}
    />
    <article class="docs-prose">
      <p>
        Start with the CLI to choose a publishing account. Research results,
        drafts, and schedules stay local and work from your terminal or any
        stdio MCP client.
      </p>
      <div class="not-prose mt-8">
        <InstallPicker standalone />
      </div>
      <div class="not-prose mt-10 grid gap-3 sm:grid-cols-2">
        {docsCards.map((doc) => (
          <a class="rounded-lg bg-muted p-5 no-underline hover:bg-secondary-hover" href={doc.href}>
            <h2 class="text-base font-semibold">{doc.title}</h2>
            <p class="mt-2 text-sm text-foreground-muted">{doc.description}</p>
          </a>
        ))}
      </div>
    </article>
  </main>
</BaseLayout>

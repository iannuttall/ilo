---
import { ASTRO_TOOLS } from '../../data/tools'
import BaseLayout from '../../layouts/BaseLayout.astro'

export const prerender = true
---

<BaseLayout title="Tools" description="Free tools for X, Twitter, Bluesky, Threads, public social data, search, media, and link previews.">
  <main class="site-frame py-16 sm:py-20" data-agent-content>
    <div class="max-w-3xl">
      <h1 class="text-4xl/none font-medium tracking-normal">Tools</h1>
      <p class="mt-4 text-2xl/8 font-medium tracking-normal text-foreground-muted">
        Free tools for X, Twitter, Bluesky, Threads, public social data, search,
        media, and link previews.
      </p>
    </div>

    <div class="mt-10 grid gap-2 sm:grid-cols-2">
      {ASTRO_TOOLS.map((tool) => (
        <a
          class="flex h-full min-h-52 flex-col rounded-lg bg-muted p-6 no-underline transition-colors hover:bg-secondary-hover"
          href={tool.href}
        >
          <h2 class="text-lg/6 font-medium tracking-normal">{tool.title}</h2>
          <p class="mt-3 text-base/7 text-foreground-muted">
            {tool.description}
          </p>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

---
import {
  formatBlogDate,
  listBlogEntries,
} from '../../../lib/content/blog-manifest'
import PageHeader from '../../components/PageHeader.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'

const posts = listBlogEntries()
---

<BaseLayout
  title="Twitter Analytics Blog: 𝕏 Growth Guides and Tools"
  description="Guides about Twitter analytics, 𝕏 growth, public social data, and the reports agents need to understand what works."
>
  <main class="site-frame py-10" data-agent-content>
    <PageHeader
      title="Learn how to understand and grow an 𝕏 account."
      description="Guides and notes about 𝕏, social data, audits, and analytics."
      bordered={false}
    />

    <div class="grid gap-2 sm:grid-cols-2">
      {posts.map((post) => (
        <a
          class="flex h-full min-h-52 flex-col rounded-lg bg-muted p-6 no-underline transition-colors hover:bg-secondary-hover"
          href={`/blog/${post.slug}`}
        >
          <p class="text-sm/6 text-foreground-soft">
            {formatBlogDate(post.date)}
          </p>
          <h2 class="mt-6 text-lg/6 font-medium tracking-normal">
            {post.title}
          </h2>
          <p class="mt-3 text-base/7 text-foreground-muted">
            {post.description}
          </p>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

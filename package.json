{
  "name": "iloso",
  "version": "0.3.1",
  "description": "A local-first social publishing CLI and MCP server for AI agents.",
  "type": "module",
  "license": "MIT",
  "author": "Ian Nuttall",
  "homepage": "https://ilo.so",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iannuttall/ilo.git"
  },
  "bugs": {
    "url": "https://github.com/iannuttall/ilo/issues"
  },
  "funding": "https://github.com/sponsors/iannuttall",
  "keywords": [
    "social-media",
    "x",
    "twitter",
    "scheduler",
    "cli",
    "mcp"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ilo": "./dist/cli.js",
    "iloso": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "LICENSE",
    "PRIVACY.md",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "turbo run build && pnpm run build:package",
    "build:package": "tsdown --config tsdown.config.ts",
    "build:web": "pnpm --filter @ilo/web... build",
    "clean": "turbo run clean && rm -rf dist",
    "dev": "turbo run dev",
    "deploy:web": "pnpm -C apps/web exec wrangler deploy",
    "deploy:web:dry-run": "pnpm build:web && pnpm -C apps/web exec wrangler deploy --dry-run",
    "lint": "biome check . && node scripts/check-emdashes.mjs && turbo run lint",
    "lint:fix": "biome check . --write",
    "pack:check": "pnpm pack --dry-run",
    "prepack": "pnpm run build:package && node --test scripts/package.test.mjs",
    "security:check": "pnpm audit --audit-level low && node scripts/security-secrets.mjs",
    "seo:parity": "node scripts/seo-parity.mjs",
    "test": "turbo run test && pnpm run build:package && node --test scripts/package.test.mjs",
    "test:package-install": "pnpm run build:package && node --test scripts/package.test.mjs",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "citty": "^0.2.2",
    "cli-table3": "^0.6.5",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "update-notifier": "^7.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^22.20.1",
    "tsdown": "^0.22.7",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3"
  }
}
